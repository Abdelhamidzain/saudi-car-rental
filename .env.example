# =============================================================================
# Environment variables — Saudi Car Rental Platform
#
# Copy this file to `.env.local` and fill in real values. Never commit
# `.env.local`. Real Supabase keys also go into Vercel project settings
# (Production, Preview, and Development environments).
# =============================================================================

# --- Public app URL ---------------------------------------------------------

# Used for canonical URLs, OG tags, sitemaps, and absolute redirects.
NEXT_PUBLIC_SITE_URL=https://saudi-car-rental.vercel.app

# --- Supabase ---------------------------------------------------------------

# Project URL — found in the Supabase dashboard under Project Settings → API.
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Project ref — the subdomain part of the URL above. Used by the Supabase CLI
# for `supabase link` and `supabase gen types --linked`.
SUPABASE_PROJECT_REF=

# Anon key — safe to expose to the browser. Subject to Row Level Security.
# In MVP this key is intentionally not used for reads (server-first model)
# but is still required for any future client-side Supabase usage.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses Row Level Security. Treat like a
# database password. Never expose to the browser; never commit to git;
# never include in client bundles. Used by `src/lib/supabase/server.ts`.
SUPABASE_SERVICE_ROLE_KEY=
